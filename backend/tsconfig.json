{
  "compilerOptions": {
    /* Runtime target */
    "target": "ES2022",
    "lib": ["ES2022"],

    /* Node module system */
    "module": "CommonJS",
    "moduleResolution": "node",

    /* Build output */
    "outDir": "./dist",

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Type checking */
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    /* Developer quality */
    "sourceMap": true
  },

  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}